POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require

# Supabase: db.<project-ref>.supabase.co is IPv6-only. On most home/office networks,
# use the Session pooler host from Dashboard → Connect instead (IPv4-compatible):
#   POSTGRES_HOST=aws-0-<region>.pooler.supabase.com
#   POSTGRES_USER=postgres.<project-ref>
#   POSTGRES_PORT=5432
# Or set a full JDBC URL override:
# POSTGRES_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# LLM provider: mock | groq
LLM_PROVIDER=mock

# Groq (when LLM_PROVIDER=groq)
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# LLM tuning
LLM_TEMPERATURE=0.7
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# Memory consolidation email (Resend)
MEMORY_REPORT_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=
MEMORY_REPORT_TO=
MEMORY_REPORT_SUBJECT=
MEMORY_REPORT_ATTACH_TXT=true
MEMORY_REPORT_ATTACH_JSON=true
MEMORY_REPORT_ATTACH_MD=true
MEMORY_REPORT_ATTACH_HTML=false
